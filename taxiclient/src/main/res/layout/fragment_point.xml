<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Point">


    <GridLayout
        android:id="@+id/edit_text_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="15dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="350dp"

        android:background="@drawable/shape"
        android:backgroundTint="@color/black_for_back"
        android:columnCount="1"
        android:rowCount="1"

        >



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginVertical="13dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="24dp"

                android:scaleType="fitXY"
                android:src="@drawable/taxi_"
                android:translationX="8dp"
                android:translationY="11dp" />

            <EditText
                android:id="@+id/edit_text_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="25dp"

                android:backgroundTint="@color/white"
                android:hint="@string/point_to_b"
                android:inputType="text"
                android:textColorHint="@color/gray"
                android:textColor="@color/white" />

        </LinearLayout>


    </GridLayout>




    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tariffs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="450dp"
        android:layout_marginHorizontal="15dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/layout"
        />
    <Button
        android:id="@+id/btn_order"
        android:layout_width="278dp"
        android:layout_height="90dp"
        android:layout_marginLeft="64dp"
        android:layout_marginTop="580dp"
        android:backgroundTint="@color/black_for_back"
        android:text="Оформить заказ"



        android:textSize="25sp"

        />


</FrameLayout>
